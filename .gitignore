node_modules/
dist/
backup/
.env
*.log
*.lnk
tmp-export/

# ---------------------------------------------------------------------------
# ffmpeg binaries & install artifacts — never commit (auto-downloaded at runtime)
# Source scripts (scripts/*ffmpeg*, lib/ensure-ffmpeg.cjs) stay tracked.
# ---------------------------------------------------------------------------

# Entire managed install dir (binaries, license, version sidecars, swap leftovers)
/bin/

# Root-level accident stubs (relative path "ffmpeg" from PATH/CWD probes)
/ffmpeg
/ffmpeg.exe
/ffprobe
/ffprobe.exe
/ffmpeg.version
/ffmpeg.exe.version
/ffmpeg.LICENSE
/ffmpeg.README

# Anywhere outside source: binary names and sidecar/swap files
ffmpeg.version
ffmpeg.exe.version
**/ffmpeg.old
**/ffmpeg.exe.old
**/ffmpeg.new
**/ffmpeg.exe.new
**/ffmpeg.download
**/ffmpeg.exe.download

# node_modules already ignored; belt-and-suspenders for extracted static binaries
node_modules/ffmpeg-static/ffmpeg
node_modules/ffmpeg-static/ffmpeg.exe
